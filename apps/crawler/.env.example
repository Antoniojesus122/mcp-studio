# ============================================================================
# MCP Studio crawler · .env
# ============================================================================

# --- Postgres (Supabase Transaction Pooler recomendado) ----------------------
POSTGRES_URL=postgresql://postgres.xxxxx:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# --- GitHub PAT (fine-grained, read-only public repos · 5000 req/h) ----------
GITHUB_TOKEN=github_pat_xxx
GITHUB_USER_AGENT=mcp-studio-crawler/0.1

# ============================================================================
# LLM provider para categorizar servidores
# ============================================================================
# Si pones varios, el orden de preferencia es: gemini > groq > anthropic.
# Si no pones ninguno, usa heurística (keyword matching, gratis y siempre).
#
# LLM_PROVIDER puede ser: auto | gemini | groq | anthropic | heuristic
# "auto" (default) elige el primero con key disponible.

LLM_PROVIDER=auto

# --- Google Gemini ★ RECOMENDADO ★ -------------------------------------------
# Free tier: 1500 req/día, gratis para siempre.
# Saca key en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Groq · alternativa rápida y gratis --------------------------------------
# Free tier: 14400 req/día con Llama 3.3 70B.
# Saca key en: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic Claude · de pago pero la mejor calidad ------------------------
# ~$5 para categorizar 600 servers una vez.
# Saca key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
