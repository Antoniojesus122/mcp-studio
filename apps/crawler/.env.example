# Postgres (Supabase Transaction Pooler URL recomendado)
POSTGRES_URL=postgresql://postgres.xxxxx:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# GitHub PAT (fine-grained, read-only public repos · 5000 req/h)
GITHUB_TOKEN=github_pat_xxx
GITHUB_USER_AGENT=mcp-studio-crawler/0.1

# Anthropic API key para categorizar (opcional pero recomendado)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-haiku-4-5
